-- CÁCH 2: Nhấn phím "M" trên bàn phím để Ẩn/Hiện Menu (Cho Máy Tính)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end -- Không kích hoạt nếu người chơi đang gõ ô chat
    if input.KeyCode == Enum.KeyCode.M then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

----------------------------------------------------------------------
-- 3. LOGIC XỬ LÝ HOẠT ẢNH VÀ TẠO DANH SÁCH NÚT CỬ ĐỘNG
----------------------------------------------------------------------
local currentTrack = nil -- Biến lưu trữ hoạt ảnh đang chạy

local function playEmote(animationId)
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")
    
    if animator then
        if currentTrack then
            currentTrack:Stop() -- Dừng cử động cũ trước khi chạy cái mới
        end
        
        local anim = Instance.new("Animation")
        anim.AnimationId = animationId
        
        currentTrack = animator:LoadAnimation(anim)
        currentTrack:Play()
    end
end

-- Vòng lặp tự động tạo các nút bấm màu tím
for i, emote in ipairs(AnimationList) do
    local Button = Instance.new("TextButton")
    Button.Name = "EmoteBtn_" .. i
    Button.Size = UDim2.new(1, 0, 0, 45)
    Button.BackgroundColor3 = Color3.fromRGB(60, 30, 90) -- Màu nút tím vừa
    Button.Text = emote.Name
    Button.TextColor3 = Color3.fromRGB(245, 235, 255) -- Chữ sáng màu tím nhạt
    Button.Font = Enum.Font.SourceSansSemibold
    Button.TextSize = 15
    Button.BorderSizePixel = 0
    Button.Parent = ScrollFrame
    
    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 8)
    ButtonCorner.Parent = Button
    
    -- Hiệu ứng đổi màu Neon cực đẹp khi di chuột vào (Hover Effect)
    Button.MouseEnter:Connect(function()
        TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(100, 40, 150)}):Play()
    end)
    Button.MouseLeave:Connect(function()
        TweenService:Create(Button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(60, 30, 90)}):Play()
    end)
    
    -- Khi người chơi nhấn vào nút cử động
    Button.MouseButton1Click:Connect(function()
        playEmote(emote.ID)
    end)
end

-- TỰ ĐỘNG DỪNG CỬ ĐỘNG KHI NHÂN VẬT DI CHUYỂN
LocalPlayer.CharacterAdded:Connect(function(char)
    local humanoid = char:WaitForChild("Humanoid")
    humanoid.Running:Connect(function(speed)
        if speed > 0.1 and currentTrack then
            currentTrack:Stop()
            currentTrack = nil
        end
    end)
end)
