-- [[ CONFIG ANIMATION ID - THAY THẾ ID CỦA BẠN TẠI ĐÂY ]]
local AnimConfig = {
    R6 = {
        dung = "rbxassetid://125750702",   -- Thay ID R6 Đứng vào đây
        chay = "rbxassetid://180426354",   -- Thay ID R6 Chạy vào đây
        nam  = "rbxassetid://13115456209"  -- Thay ID R6 Nằm vào đây
    },
    R15 = {
        dung = "rbxassetid://507766388",   -- Thay ID R15 Đứng vào đây
        chay = "rbxassetid://507766666",   -- Thay ID R15 Chạy vào đây
        nam  = "rbxassetid://13115456209"  -- Thay ID R15 Nằm vào đây
    }
}

-- [[ KHỞI TẠO BIẾN HỆ THỐNG ]]
local Players = game:GetService("Players")
local lplayer = Players.LocalPlayer
local char = lplayer.Character or lplayer.CharacterAdded:Wait()
local humanoid = char:WaitForChild("Humanoid")
local currentTrack = nil

-- Tự động kiểm tra loại nhân vật R6 hay R15
local currentRig = (humanoid.RigType == Enum.HumanoidRigType.R15) and "R15" or "R6"

-- Hàm kích hoạt hoạt ảnh
local function PlayAnim(animType)
    if currentTrack then currentTrack:Stop() end
    
    local animId = AnimConfig[currentRig][animType]
    local animation = Instance.new("Animation")
    animation.AnimationId = animId
    
    local success, track = pcall(function()
        return humanoid:LoadAnimation(animation)
    end)
    
    if success and track then
        -- Nếu là dáng Nằm hoặc Đứng, ta lặp vô tận (Loop)
        if animType == "nam" or animType == "dung" then
            track.Looped = true
        else
            track.Looped = false
        end
        track:Play()
        currentTrack = track
    else
        warn("Không thể tải Animation ID. Hãy kiểm tra lại quyền sở hữu ID!")
    end
end

-- [[ TẠO GIAO DIỆN UI MOBILE TRỰC QUAN ]]
-- Xóa GUI cũ nếu có để tránh trùng lặp
local oldGui = lplayer.PlayerGui:FindFirstChild("AnimMenuMobile")
if oldGui then oldGui:Destroy() end

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "AnimMenuMobile"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = lplayer.PlayerGui

-- Khung chứa chính (Menu Frame)
local MainFrame = Instance.new("Frame")
MainFrame.Size = UDim2.new(0, 160, 0, 240)
MainFrame.Position = UDim2.new(0.05, 0, 0.3, 0) -- Nằm bên góc trái màn hình điện thoại
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Draggable = true -- Có thể giữ và kéo menu di chuyển trên màn hình cảm ứng
MainFrame.Parent = ScreenGui

-- Bo góc cho Menu
local UICorner = Instance.new("UICorner")
