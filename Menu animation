-- Tiêu đề Menu
local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 40)
Title.Text = "ANIM MENU (" .. currentRig .. ")"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 14
Title.Font = Enum.Font.SourceSansBold
Title.BackgroundTransparency = 1
Title.Parent = MainFrame

-- Thiết kế các nút bấm nhanh (Đứng, Chạy, Nằm, Reset)
local function CreateButton(name, text, color, positionY, callback)
    local Button = Instance.new("TextButton")
    Button.Name = name
    Button.Size = UDim2.new(0, 130, 0, 35)
    Button.Position = UDim2.new(0.5, -65, 0, positionY)
    Button.BackgroundColor3 = color
    Button.Text = text
    Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    Button.TextSize = 14
    Button.Font = Enum.Font.SourceSansBold
    Button.BorderSizePixel = 0
    Button.Parent = MainFrame
    
    local BCorner = Instance.new("UICorner")
    BCorner.CornerRadius = UDim.new(0, 6)
    BCorner.Parent = Button
    
    Button.MouseButton1Click:Connect(callback)
end

-- Khởi tạo chức năng cụ thể cho từng nút bấm
CreateButton("BtnDung", "🚶 ĐÁNG ĐỨNG", Color3.fromRGB(46, 117, 89), 50, function()
    PlayAnim("dung")
end)

CreateButton("BtnChay", "🏃 DÁNG CHẠY", Color3.fromRGB(31, 78, 121), 95, function()
    PlayAnim("chay")
end)

CreateButton("BtnNam", "🛏️ DÁNG NẰM", Color3.fromRGB(123, 44, 121), 140, function()
    PlayAnim("nam")
end)

CreateButton("BtnReset", "❌ TẮT ANIM", Color3.fromRGB(150, 40, 40), 185, function()
    if currentTrack then 
        currentTrack:Stop() 
        currentTrack = nil
    end
end)

-- Tự động cập nhật lại thông tin khi nhân vật bị reset/hồi sinh
lplayer.CharacterAdded:Connect(function(newChar)
    char = newChar
    humanoid = char:WaitForChild("Humanoid")
    currentRig = (humanoid.RigType == Enum.HumanoidRigType.R15) and "R15" or "R6"
    Title.Text = "ANIM MENU (" .. currentRig .. ")"
    currentTrack = nil
end)
